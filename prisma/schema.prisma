generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ================================================================
// ENUMS
// ================================================================

enum Role {
  CEO
  KMD
  AL
  AT
  AD
  TL
  PEER_REVIEWER
  ADMIN
}

enum Stage {
  SOURCED
  SCOPING
  SCREENING_MATERIALS_REQUESTED
  CONCEPT_REVIEW
  CONCEPT_DECISION
  APPLICATION_REQUESTED
  APPLICATION_RECEIVED
  APPLICATION_REVIEW
  MEMO_DRAFTING
  PEER_REVIEW
  CEO_COMMITTEE_REVIEW
  MEMO_DECISION
  LEGAL_DUE_DILIGENCE
  LEGAL_DD_COMPLETE
  ONBOARDING
  ACTIVE
}

enum OrgType {
  NGO
  COMPANY
  INDIVIDUAL
  OTHER
}

enum ScopingCallStatus {
  NOT_SCHEDULED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum DecisionOutcome {
  APPROVED
  REJECTED
  REVISION_REQUESTED
  CONDITIONALLY_APPROVED
  DEFERRED
}

enum DecisionType {
  CONCEPT
  MEMO
  STRATEGY
}

enum ApplicationStatus {
  REQUESTED
  RECEIVED
  IN_REVIEW
  COMPLETE
  REJECTED
}

enum ReviewReportStatus {
  IN_PROGRESS
  AL_SIGNED
  KMD_SIGNED
  COMPLETE
}

enum MemoStatus {
  DRAFT
  IN_PEER_REVIEW
  IN_CEO_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum PeerReviewStatus {
  NOT_ASSIGNED
  ASSIGNED
  IN_REVIEW
  QUESTIONS_SENT
  AL_RESPONSE_PENDING
  COMPLETE
}

enum LegalDDCaseStatus {
  NOT_STARTED
  REQUESTED
  DOCUMENTS_PENDING
  SUBMITTED
  UNDER_AD_REVIEW
  REVISIONS_REQUESTED
  RESUBMITTED
  TRUST_VALIDATION
  VALIDATED
  REJECTED
  COMPLETE
}

enum TrustValidationStatus {
  NOT_SENT
  SENT
  VALIDATED
  REJECTED
}

enum ChecklistItemStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  REVISION_REQUESTED
}

enum GrantStatus {
  ACTIVE
  CLOSED
  PAUSED
}

enum GrantOnboardingStatus {
  NOT_STARTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum SupportType {
  MEL
  TECH
  STRATEGIC
}

enum StrategyDocType {
  PROCESS_MAP
  INVESTMENT_CRITERIA
  TOC
  THESIS
  LEARNING_AGENDA
}

enum StrategyDocStatus {
  DRAFT
  IN_REVIEW
  APPROVED
}

enum DocumentType {
  STRATEGY
  CONCEPT_NOTE
  INSTITUTIONAL_DECK
  FULL_APPLICATION
  APPLICATION_REVIEW_REPORT
  INVESTMENT_MEMO
  PEER_REVIEW_COMMENTS
  CEO_NOTES
  LEGAL_DOCUMENT
  TRUST_VALIDATION
  KICKOFF_MINUTES
  KPI_REPORTING_AGREEMENT
  OTHER
}

enum DocumentVisibility {
  INTERNAL
  EXTERNAL
}

enum CommentRelatedType {
  INITIATIVE
  CONCEPT_NOTE
  APPLICATION
  MEMO
  DOCUMENT
}

enum MeetingType {
  CONCEPT_REVIEW
  MEMO_REVIEW
  KICKOFF
}

enum NotificationType {
  CONCEPT_NOTE_SENT_TO_CEO
  CEO_DECISION_RECORDED
  APPLICATION_RECEIVED
  PEER_REVIEWER_ASSIGNED
  PEER_COMMENT_SUBMITTED
  AL_RESPONSE_NEEDED
  MEMO_SENT_TO_CEO
  LEGAL_DD_STARTED
  LEGAL_DOCUMENT_UPLOADED
  LEGAL_REVISION_REQUESTED
  LEGAL_DD_COMPLETED
  ONBOARDING_STARTED
}

enum AuditAction {
  CREATE
  UPDATE
  STAGE_CHANGE
  DECISION_RECORDED
  LEGAL_STATUS_CHANGE
  DOCUMENT_UPLOADED
  USER_INVITED
  USER_DEACTIVATED
}

// Simplified rollup statuses on Initiative — kept in sync by the workflow layer
enum InitiativeLegalDDStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  REJECTED
}

enum InitiativeOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ================================================================
// CORE ENTITIES
// ================================================================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         Role
  passwordHash String
  areaId       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  area                  Area?                     @relation(fields: [areaId], references: [id])
  ownedInitiatives      Initiative[]              @relation("InitiativeAL")
  authoredMemos         InvestmentMemo[]          @relation("MemoAuthor")
  ownedStrategyDocs     StrategyDocument[]        @relation("StrategyOwner")
  approvedStrategyDocs  StrategyDocument[]        @relation("StrategyApprover")
  leadGrants            Grant[]                   @relation("GrantLead")
  kmdReportReviews      ApplicationReviewReport[] @relation("KmdReviewer")
  alApplications        Application[]             @relation("ApplicationAL")
  managedCases          LegalDueDiligenceCase[]   @relation("CaseAD")
  supportedInitiatives  InitiativeSupport[]
  comments              Comment[]
  decisions             Decision[]
  peerReviews           PeerReview[]
  uploadedDocuments     Document[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  meetingParticipations MeetingParticipant[]
  reviewedItems         LegalChecklistItem[]      @relation("ReviewedBy")
  revisionRequests      RevisionRequest[]
}

model Area {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  initiatives  Initiative[]
  strategyDocs StrategyDocumentArea[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  legalName   String?
  country     String
  website     String?
  type        OrgType
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts     Contact[]
  initiatives  Initiative[]
  documents    Document[]
  applications Application[]
  legalCases   LegalDueDiligenceCase[]
  grants       Grant[]
}

model Contact {
  id             String   @id @default(cuid())
  fullName       String
  email          String
  phone          String?
  title          String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization?       @relation(fields: [organizationId], references: [id])
  initiatives           InitiativeContact[]
  primaryForInitiatives Initiative[]        @relation("PrimaryContact")
}

model InitiativeContact {
  initiativeId String
  contactId    String

  initiative Initiative @relation(fields: [initiativeId], references: [id])
  contact    Contact    @relation(fields: [contactId], references: [id])

  @@id([initiativeId, contactId])
}

model InitiativeSupport {
  initiativeId String
  userId       String

  initiative Initiative @relation(fields: [initiativeId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@id([initiativeId, userId])
}

model Initiative {
  id                     String                     @id @default(cuid())
  name                   String
  organizationId         String?
  individualName         String?
  primaryContactId       String?
  areaId                 String
  country                String
  summary                String
  source                 String?
  stage                  Stage                      @default(SOURCED)
  assignedAlId           String
  fitScore               Float?
  thematicAlignment      String?
  scopingCallStatus      ScopingCallStatus?
  scopingCallNotes       String?
  scopingCallDate        DateTime?
  strategicFitNotes      String?
  solutionStrengthNotes  String?
  executionCapacityNotes String?
  criteriaSetId          String?
  needsTechReview        Boolean                    @default(false)
  ceoDecisionStatus      DecisionOutcome?
  legalDdStatus          InitiativeLegalDDStatus?
  onboardingStatus       InitiativeOnboardingStatus?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  organization   Organization?       @relation(fields: [organizationId], references: [id])
  primaryContact Contact?            @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  area           Area                @relation(fields: [areaId], references: [id])
  assignedAl     User                @relation("InitiativeAL", fields: [assignedAlId], references: [id])
  criteriaSet    CriteriaSet?        @relation(fields: [criteriaSetId], references: [id])
  supportingAt   InitiativeSupport[]
  contacts       InitiativeContact[]
  documents      Document[]
  meetings       Meeting[]
  application    Application?
  legalDdCase    LegalDueDiligenceCase?
  grant          Grant?
  decisions      Decision[]
  // auditLogs fetched via query: prisma.auditLog.findMany({ where: { entityType: 'INITIATIVE', entityId: id } })

  @@index([stage])
  @@index([assignedAlId])
  @@index([areaId])
  @@index([country])
}

// ================================================================
// PIPELINE / REVIEW
// ================================================================

model Application {
  id             String            @id @default(cuid())
  initiativeId   String            @unique
  organizationId String
  type           String?
  status         ApplicationStatus @default(REQUESTED)
  criteriaSetId  String?
  whyYes         String?
  whyNot         String?
  submittedDate  DateTime?
  alId           String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  initiative   Initiative              @relation(fields: [initiativeId], references: [id])
  organization Organization            @relation(fields: [organizationId], references: [id])
  criteriaSet  CriteriaSet?            @relation(fields: [criteriaSetId], references: [id])
  al           User                    @relation("ApplicationAL", fields: [alId], references: [id])
  reviewReport ApplicationReviewReport?
  documents    Document[]
}

model ApplicationReviewReport {
  id             String             @id @default(cuid())
  applicationId  String             @unique
  status         ReviewReportStatus @default(IN_PROGRESS)
  alSignOffAt    DateTime?
  kmdSignOffAt   DateTime?
  kmdReviewerId  String?
  protocolNotes  String?
  reviewComments String?
  completedDate  DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  application  Application    @relation(fields: [applicationId], references: [id])
  kmdReviewer  User?          @relation("KmdReviewer", fields: [kmdReviewerId], references: [id])
  memo         InvestmentMemo?
}

model InvestmentMemo {
  id             String     @id @default(cuid())
  reviewReportId String     @unique
  authorAlId     String
  reviewStatus   MemoStatus @default(DRAFT)
  body           String?
  ceoQuestions   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  reviewReport ApplicationReviewReport @relation(fields: [reviewReportId], references: [id])
  authorAl     User                    @relation("MemoAuthor", fields: [authorAlId], references: [id])
  peerReviews  PeerReview[]
}

model PeerReview {
  id            String           @id @default(cuid())
  memoId        String
  reviewerId    String
  status        PeerReviewStatus @default(NOT_ASSIGNED)
  reviewText    String?
  assignedDate  DateTime
  completedDate DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  memo     InvestmentMemo @relation(fields: [memoId], references: [id])
  reviewer User           @relation(fields: [reviewerId], references: [id])

  @@index([memoId])
}

model Decision {
  id                String          @id @default(cuid())
  initiativeId      String
  type              DecisionType
  decision          DecisionOutcome
  rationale         String?
  conditions        String?
  decidedById       String
  decidedAt         DateTime
  relatedDocumentId String?
  createdAt         DateTime        @default(now())

  initiative      Initiative @relation(fields: [initiativeId], references: [id])
  decidedBy       User       @relation(fields: [decidedById], references: [id])
  relatedDocument Document?  @relation(fields: [relatedDocumentId], references: [id])

  @@index([initiativeId])
}

// Polymorphic — relatedType+relatedId resolved in app layer (not Prisma relations)
// Fetch: prisma.comment.findMany({ where: { relatedType, relatedId } })
model Comment {
  id          String             @id @default(cuid())
  body        String
  authorId    String
  relatedType CommentRelatedType
  relatedId   String
  isInternal  Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([relatedType, relatedId])
}

model Meeting {
  id                   String      @id @default(cuid())
  initiativeId         String
  type                 MeetingType
  title                String
  dateTime             DateTime
  externalParticipants String?
  agenda               String?
  minutes              String?
  decisions            String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  initiative   Initiative          @relation(fields: [initiativeId], references: [id])
  participants MeetingParticipant[]
  kickoffGrant Grant?              @relation("KickoffMeeting")

  @@index([initiativeId])
}

model MeetingParticipant {
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([meetingId, userId])
}

// ================================================================
// LEGAL DUE DILIGENCE
// ================================================================

model LegalDueDiligenceCase {
  id                    String                 @id @default(cuid())
  initiativeId          String                 @unique
  organizationId        String
  status                LegalDDCaseStatus      @default(NOT_STARTED)
  adId                  String
  revisionCount         Int                    @default(0)
  trustValidationStatus TrustValidationStatus?
  complianceNotes       String?
  completedDate         DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  initiative       Initiative           @relation(fields: [initiativeId], references: [id])
  organization     Organization         @relation(fields: [organizationId], references: [id])
  ad               User                 @relation("CaseAD", fields: [adId], references: [id])
  checklistItems   LegalChecklistItem[]
  revisionRequests RevisionRequest[]
}

model LegalChecklistItem {
  id              String              @id @default(cuid())
  caseId          String
  requiredDocName String
  description     String?
  isRequired      Boolean             @default(true)
  documentId      String?
  status          ChecklistItemStatus @default(PENDING)
  revisionNotes   String?
  reviewedById    String?
  reviewedDate    DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  case       LegalDueDiligenceCase @relation(fields: [caseId], references: [id])
  document   Document?             @relation(fields: [documentId], references: [id])
  reviewedBy User?                 @relation("ReviewedBy", fields: [reviewedById], references: [id])
  revisions  RevisionRequest[]

  @@index([caseId])
}

model RevisionRequest {
  id              String    @id @default(cuid())
  caseId          String
  checklistItemId String?
  notes           String
  requestedById   String
  requestedAt     DateTime  @default(now())
  resolvedAt      DateTime?

  case          LegalDueDiligenceCase @relation(fields: [caseId], references: [id])
  checklistItem LegalChecklistItem?   @relation(fields: [checklistItemId], references: [id])
  requestedBy   User                  @relation(fields: [requestedById], references: [id])
}

// ================================================================
// ONBOARDING / GRANT
// ================================================================

model Grant {
  id                  String                @id @default(cuid())
  initiativeId        String                @unique
  organizationId      String
  status              GrantStatus           @default(ACTIVE)
  amount              Float?
  currency            String?
  supportType         SupportType[]
  reportingCadence    String?
  nextReportDue       DateTime?
  areaLeadId          String
  onboardingStatus    GrantOnboardingStatus @default(NOT_STARTED)
  kickoffMeetingId    String?               @unique
  scope               String?
  reportingConditions String?
  onboardingMinutes   String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  initiative     Initiative   @relation(fields: [initiativeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  areaLead       User         @relation("GrantLead", fields: [areaLeadId], references: [id])
  kickoffMeeting Meeting?     @relation("KickoffMeeting", fields: [kickoffMeetingId], references: [id])
  kpis           KPI[]
}

model KPI {
  id          String   @id @default(cuid())
  grantId     String
  name        String
  description String?
  target      String?
  cadence     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grant Grant @relation(fields: [grantId], references: [id])
}

// ================================================================
// STRATEGY & CRITERIA
// ================================================================

model StrategyDocument {
  id           String            @id @default(cuid())
  title        String
  type         StrategyDocType
  status       StrategyDocStatus @default(DRAFT)
  version      Int               @default(1)
  ownerId      String
  approvedById String?
  approvalDate DateTime?
  fileUrl      String?
  body         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  owner      User                   @relation("StrategyOwner", fields: [ownerId], references: [id])
  approvedBy User?                  @relation("StrategyApprover", fields: [approvedById], references: [id])
  areas      StrategyDocumentArea[]
}

model StrategyDocumentArea {
  strategyDocumentId String
  areaId             String

  strategyDocument StrategyDocument @relation(fields: [strategyDocumentId], references: [id])
  area             Area             @relation(fields: [areaId], references: [id])

  @@id([strategyDocumentId, areaId])
}

model CriteriaSet {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items        CriteriaItem[]
  initiatives  Initiative[]
  applications Application[]
}

model CriteriaItem {
  id        String   @id @default(cuid())
  setId     String
  label     String
  guidance  String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  set CriteriaSet @relation(fields: [setId], references: [id])
}

// ================================================================
// SYSTEM
// ================================================================

model Document {
  id             String             @id @default(cuid())
  initiativeId   String?
  organizationId String?
  applicationId  String?
  type           DocumentType
  stage          Stage?
  fileName       String
  storageKey     String
  uploadedById   String
  uploadedAt     DateTime           @default(now())
  version        Int                @default(1)
  status         String?
  visibility     DocumentVisibility @default(INTERNAL)
  notes          String?

  initiative     Initiative?   @relation(fields: [initiativeId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  application    Application?  @relation(fields: [applicationId], references: [id])
  uploadedBy     User          @relation(fields: [uploadedById], references: [id])
  checklistItems LegalChecklistItem[]
  decisions      Decision[]

  @@index([initiativeId])
  @@index([type])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  message     String
  relatedType String?
  relatedId   String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

// Append-only — never UPDATE or DELETE rows
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime    @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
}
